generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model proxmox_pools {
  id          String   @id @default(uuid())
  external_id String   @unique
  name        String
}

model vm_inventory {
  id              String   @id @default(uuid())
  vmid            Int      @unique
  name            String?
  node            String?
  pool_id         String?
  tenant_id       String?
  tenant_group_id String?
  status          String?
  cpu             Int?
  memory          BigInt?
  disk            BigInt?
  created_at      DateTime @default(now())
}