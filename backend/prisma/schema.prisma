generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id              String   @id @default(uuid())
  keycloak_id     String   @unique
  email           String
  tenant_group_id String?
  created_at      DateTime @default(now())
}

model tenants {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  status     String
  created_at DateTime @default(now())
}

model tenant_groups {
  id         String   @id @default(uuid())
  tenant_id  String
  code       String
  name       String
  created_at DateTime @default(now())
}

model proxmox_pools {
  id          String @id @default(uuid())
  external_id String @unique
  name        String
}

model tenant_group_pools {
  id              String @id @default(uuid())
  tenant_group_id String
  proxmox_pool_id String
}

model vm_inventory {
  id                    String   @id @default(uuid())
  vmid                  Int      @unique
  name                  String?
  node                  String?
  pool_id               String?
  tenant_id             String?
  tenant_group_id       String?
  status                String?
  cpu                   Int?
  memory                BigInt?
  disk                  BigInt?
  os_type               String?
  elastic_host_name     String?
  kibana_base_url       String?
  monitored_services    String?
  observability_enabled Boolean  @default(true)
  created_at            DateTime @default(now())
}

model audit_logs {
  id         String   @id @default(uuid())
  user_id    String?
  action     String
  target     String
  result     String
  created_at DateTime @default(now())
}